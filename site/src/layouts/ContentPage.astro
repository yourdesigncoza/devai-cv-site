---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  breadcrumbLabel?: string;
  breadcrumbHref?: string;
}

const { title, description, image, type, publishedTime, breadcrumbLabel, breadcrumbHref } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type={type} publishedTime={publishedTime}>
  <div class="max-w-6xl mx-auto px-4 pt-4 pb-12">
    <div class="relative max-w-3xl mx-auto bg-white rounded-xl shadow-card-cal p-8 md:p-12">
      <span class="absolute top-2 left-4 text-gray-300 text-2xl font-mono select-none pointer-events-none" aria-hidden="true">+</span>
      <span class="absolute top-2 right-4 text-gray-300 text-2xl font-mono select-none pointer-events-none" aria-hidden="true">+</span>
      <span class="absolute bottom-2 left-4 text-gray-300 text-2xl font-mono select-none pointer-events-none" aria-hidden="true">+</span>
      <span class="absolute bottom-2 right-4 text-gray-300 text-2xl font-mono select-none pointer-events-none" aria-hidden="true">+</span>

      {breadcrumbHref && (
        <a href={breadcrumbHref} class="text-sm text-gray-500 hover:text-brand-600">&larr; {breadcrumbLabel ?? 'back'}</a>
      )}

      <article class="prose-content">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .prose-content h1 {
    margin-top: 1.25rem;
    font-size: 1.875rem;
    line-height: 1.1;
    letter-spacing: -0.025em;
    word-spacing: 0.1em;
    font-weight: 500;
    color: #242424;
  }
  @media (min-width: 768px) {
    .prose-content h1 { font-size: 44px; }
  }
  .prose-content h2 {
    margin-top: 3.5rem;
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.025em;
    word-spacing: 0.1em;
    color: #242424;
  }
  @media (min-width: 768px) {
    .prose-content h2 { font-size: 1.875rem; }
  }
  .prose-content h3 {
    margin-top: 2rem;
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.025em;
    word-spacing: 0.1em;
    color: #242424;
  }
  .prose-content p {
    margin-top: 1.25rem;
    line-height: 1.7;
    color: #374151;
  }
  .prose-content p:first-of-type {
    font-size: 1.125rem;
    color: #4b5563;
  }
  .prose-content a {
    color: #1f47e0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .prose-content a:hover { color: #1a3bb8; }
  .prose-content ul, .prose-content ol {
    margin-top: 1rem;
    padding-left: 1.25rem;
    color: #374151;
    line-height: 1.7;
  }
  .prose-content ul { list-style: disc; }
  .prose-content ol { list-style: decimal; }
  .prose-content li { margin-top: 0.5rem; }
  .prose-content li::marker { color: #9ca3af; font-weight: 600; }
  .prose-content blockquote {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    border-left: 3px solid #e1e2e3;
    color: #4b5563;
    font-style: italic;
  }
  .prose-content code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: #f4f4f4;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    color: #242424;
  }
  .prose-content pre {
    margin-top: 1.5rem;
    padding: 1rem;
    border: 1px solid #e1e2e3;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.55;
  }
  .prose-content pre,
  .prose-content pre code {
    font-family: var(--font-mono);
  }
  .prose-content pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .prose-content hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid #e1e2e3;
  }
  .prose-content img {
    margin-top: 1.5rem;
    border-radius: 8px;
  }
</style>
