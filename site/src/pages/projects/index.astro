---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import ContentPage from '../../layouts/ContentPage.astro';
import edenfintechScannerHero from '../../content/projects/edenfintech-scanner-hero.png';
import edenfintechHero from '../../content/projects/edenfintech-hero.png';
import jobabroadHero from '../../content/projects/jobabroad-hero.png';
import signaltraceHero from '../../content/projects/signaltrace-hero.png';
import wecozaHero from '../../content/projects/wecoza-hero.png';
import yourdesignHero from '../../content/projects/yourdesign-hero.png';

const heroImages: Record<string, ImageMetadata> = {
  'edenfintech-scanner-python': edenfintechScannerHero,
  'edenfintech-com': edenfintechHero,
  'jobabroad-co-za': jobabroadHero,
  'signaltrace-site': signaltraceHero,
  'wecoza-development': wecozaHero,
  'yourdesign-co-za': yourdesignHero,
};

// Projects without a hero image fall back to their own generated OG card,
// so every tile shows on-brand artwork instead of a flat placeholder.
const ogCardUrl = (title: string, description?: string) => {
  const params = new URLSearchParams({ title });
  if (description) params.set('description', description);
  return `/og.png?${params.toString()}`;
};

const entries = (await getCollection('projects')).filter((p) => !p.data.draft);

const STATUS_ORDER = ['active', 'maintained', 'archived'];
const STATUS_LABEL: Record<string, string> = {
  active: 'Currently building',
  maintained: 'Maintained',
  archived: 'Archived',
};

const grouped = STATUS_ORDER.map((status) => ({
  status,
  label: STATUS_LABEL[status],
  items: entries
    .filter((e) => (e.data.status ?? 'archived') === status)
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
})).filter((g) => g.items.length > 0);
---

<ContentPage
  title="Projects"
  description="Currently building, maintained, and archived projects from John Montgomery's portfolio."
  breadcrumbLabel="devai.co.za"
  breadcrumbHref="/"
>
  <h1>Projects</h1>
  <p>What I've built and what I'm still building. The active ones are where the current week goes.</p>

  {grouped.map((group, idx) => (
    <section class="not-prose mt-12">
      <div class="flex items-baseline gap-3">
        <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-gray-100 text-gray-700 text-xs font-mono font-semibold">
          {String(idx + 1).padStart(2, '0')}
        </span>
        <h2 class="text-xl md:text-2xl font-medium [word-spacing:0.1em] text-[#242424]">{group.label}</h2>
      </div>

      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {group.items.map((p) => {
          const img = heroImages[p.id];
          return (
            <a href={`/projects/${p.id}`} class="group block rounded-lg border border-[#e1e2e3] bg-white overflow-hidden hover:shadow-card-cal transition-shadow no-underline!">
              <span class="block aspect-[16/9] overflow-hidden bg-[#fbfbfb]">
                {img ? (
                  <Image src={img} alt="" loading="lazy" widths={[400, 800]} sizes="(min-width: 640px) 50vw, 100vw" class="w-full h-full object-cover" />
                ) : (
                  <img src={ogCardUrl(p.data.title, p.data.description)} alt="" loading="lazy" class="w-full h-full object-cover" />
                )}
              </span>
              <span class="block p-4">
                <span class="block text-sm font-semibold text-[#242424] group-hover:text-brand-600 transition-colors">{p.data.title}</span>
                {p.data.description && (
                  <span class="block mt-1 text-sm text-gray-600 leading-relaxed line-clamp-3">{p.data.description}</span>
                )}
                <span class="block mt-3 text-xs font-medium text-brand-600 group-hover:underline">Read more &rarr;</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  ))}
</ContentPage>
