---
import { getCollection, render } from 'astro:content';
import ContentPage from '../../layouts/ContentPage.astro';

export async function getStaticPaths() {
  const collections = [
    'skills',
    'projects',
    'decisions',
    'playbooks',
    'influences',
    'notes',
    'open-questions',
    'about',
  ] as const;
  const all = await Promise.all(
    collections.map(async (name) => {
      const entries = await getCollection(name);
      return entries
        .filter((e) => !e.data.draft)
        .filter((e) => !(name === 'about' && e.id === 'index'))
        .map((entry) => ({
          params: {
            collection: name,
            slug: entry.id === 'index' ? undefined : entry.id,
          },
          props: { entry, collection: name },
        }));
    }),
  );
  return all.flat();
}

const { entry, collection } = Astro.props;
const { Content } = await render(entry);

const breadcrumbLabel = collection === 'about' ? 'devai.co.za' : collection.replace('-', ' ');
const breadcrumbHref = collection === 'about' ? '/' : `/${collection}`;
---

<ContentPage
  title={entry.data.title}
  description={entry.data.description}
  breadcrumbLabel={breadcrumbLabel}
  breadcrumbHref={breadcrumbHref}
>
  <h1>{entry.data.title}</h1>
  <Content />
</ContentPage>
