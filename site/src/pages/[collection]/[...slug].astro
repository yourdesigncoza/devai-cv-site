---
import { getCollection, render } from 'astro:content';
import ContentPage from '../../layouts/ContentPage.astro';

export async function getStaticPaths() {
  const collections = [
    'method',
    'services',
    'case-studies',
    'audiences',
    'skills',
    'projects',
    'decisions',
    'playbooks',
    'influences',
    'notes',
    'open-questions',
    'about',
  ] as const;
  // Collections whose index is rendered by a bespoke .astro landing page,
  // so their markdown index (if any) must not also claim the route.
  const customIndexCollections = new Set([
    'about',
    'services',
    'case-studies',
    'audiences',
  ]);
  const all = await Promise.all(
    collections.map(async (name) => {
      const entries = await getCollection(name);
      return entries
        .filter((e) => !e.data.draft)
        .filter((e) => !(customIndexCollections.has(name) && e.id === 'index'))
        .map((entry) => ({
          params: {
            collection: name,
            slug: entry.id === 'index' ? undefined : entry.id,
          },
          props: { entry, collection: name },
        }));
    }),
  );
  return all.flat();
}

const { entry, collection } = Astro.props;
const { Content } = await render(entry);

const isIndex = entry.id === 'index';
const breadcrumbLabel = collection === 'about' || isIndex ? 'devai.co.za' : collection.replace('-', ' ');
const breadcrumbHref = collection === 'about' || isIndex ? '/' : `/${collection}`;
---

<ContentPage
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  publishedTime={entry.data.date}
  breadcrumbLabel={breadcrumbLabel}
  breadcrumbHref={breadcrumbHref}
>
  <h1>{entry.data.title}</h1>
  <Content />
</ContentPage>
