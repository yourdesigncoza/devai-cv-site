---
import { getCollection } from 'astro:content';
import ContentPage from '../../layouts/ContentPage.astro';

const decisions = (await getCollection('decisions'))
  .filter((d) => !d.data.draft)
  .sort((a, b) => {
    const ta = a.data.date?.getTime() ?? 0;
    const tb = b.data.date?.getTime() ?? 0;
    return tb - ta;
  });

const fmt = (d?: Date) =>
  d ? d.toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
---

<ContentPage
  title="Decisions"
  description="Architectural positions and methodology choices. First-person stances with the reasoning attached."
  breadcrumbLabel="devai.co.za"
  breadcrumbHref="/"
>
  <h1>Decisions</h1>
  <p>Positions I hold, with the reasoning attached. Each one is a stance I'd defend, not a casual note.</p>

  <ol class="decisions-list">
    {decisions.map((d, i) => (
      <li>
        <div class="row-head">
          <span class="num-pill">{String(i + 1).padStart(2, '0')}</span>
          {d.data.date && <span class="row-date">{fmt(d.data.date)}</span>}
        </div>
        <h2 class="row-title">{d.data.title}</h2>
        {d.data.description && <p class="row-desc">{d.data.description}</p>}
        <a href={`/decisions/${d.id}`} class="read-button">
          Read full position <span aria-hidden="true">&rarr;</span>
        </a>
      </li>
    ))}
  </ol>
</ContentPage>

<style>
  .decisions-list {
    list-style: none !important;
    padding-left: 0 !important;
    margin-top: 2.5rem;
  }
  .decisions-list > li {
    margin-top: 3.5rem;
    padding-left: 0;
  }
  .decisions-list > li:first-child {
    margin-top: 2rem;
  }
  .decisions-list > li::marker {
    content: none;
  }
  .row-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .num-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    background: #f3f4f6;
    color: #374151;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
  }
  .row-date {
    color: #6b7280;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .decisions-list h2.row-title {
    margin-top: 1rem !important;
    font-size: 1.5rem;
    line-height: 1.25;
    font-weight: 500;
    word-spacing: 0.1em;
    color: #242424;
  }
  @media (min-width: 768px) {
    .decisions-list h2.row-title { font-size: 1.875rem; }
  }
  .decisions-list p.row-desc {
    margin-top: 1rem !important;
    font-size: 1rem !important;
    color: #4b5563;
    line-height: 1.7;
    max-width: 65ch;
  }
  .read-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.375rem;
    background: #f3f4f6;
    color: #374151 !important;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: background-color 150ms ease, color 150ms ease;
  }
  .read-button:hover {
    background: #e5e7eb;
    color: #1f2937 !important;
  }
</style>
