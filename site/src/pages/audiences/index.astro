---
import { getCollection } from 'astro:content';
import ContentPage from '../../layouts/ContentPage.astro';

const audiences = (await getCollection('audiences'))
  .filter((a) => !a.data.draft && a.id !== 'index')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<ContentPage
  title="Who I help"
  description="Three ways in, depending on who you are: business owners who need a useful tool not AI theatre, agencies who need depth on a client build, and investors who need research where evidence and downside matter."
  breadcrumbLabel="devai.co.za"
  breadcrumbHref="/"
>
  <h1>Who I help</h1>
  <p>Same builder, three starting points. Find the one that sounds like you.</p>

  <ol class="card-list">
    {audiences.map((a) => (
      <li>
        <h2 class="row-title">{a.data.title}</h2>
        {a.data.description && <p class="row-desc">{a.data.description}</p>}
        <a href={`/audiences/${a.id}`} class="read-button">
          Read more <span aria-hidden="true">&rarr;</span>
        </a>
      </li>
    ))}
  </ol>
</ContentPage>

<style>
  .card-list {
    list-style: none !important;
    padding-left: 0 !important;
    margin-top: 2.5rem;
  }
  .card-list > li { margin-top: 3rem; padding-left: 0; }
  .card-list > li:first-child { margin-top: 2rem; }
  .card-list > li::marker { content: none; }
  .card-list h2.row-title {
    margin-top: 0 !important;
    font-size: 1.5rem;
    line-height: 1.25;
    font-weight: 500;
    word-spacing: 0.1em;
    color: #242424;
  }
  @media (min-width: 768px) {
    .card-list h2.row-title { font-size: 1.875rem; }
  }
  .card-list p.row-desc {
    margin-top: 1rem !important;
    font-size: 1rem !important;
    color: #4b5563;
    line-height: 1.7;
    max-width: 65ch;
  }
  .read-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.375rem;
    background: #f3f4f6;
    color: #374151 !important;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: background-color 150ms ease, color 150ms ease;
  }
  .read-button:hover { background: #e5e7eb; color: #1f2937 !important; }
</style>
