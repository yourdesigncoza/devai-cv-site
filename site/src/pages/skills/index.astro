---
import { getCollection } from 'astro:content';
import ContentPage from '../../layouts/ContentPage.astro';

const skills = (await getCollection('skills'))
  .filter((s) => !s.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<ContentPage
  title="Skills"
  description="What John Montgomery does. Six areas of practice across quant engineering, AI/agent systems, WordPress craft, knowledge graphs, Python pipelines, and design."
  breadcrumbLabel="devai.co.za"
  breadcrumbHref="/"
>
  <h1>Skills</h1>
  <p>Six areas of practice. Each page has projects, decisions, and proof points underneath.</p>

  <ul class="not-prose mt-8 space-y-4">
    {skills.map((s) => (
      <li class="group">
        <a href={`/skills/${s.id}`} class="block rounded-lg border border-[#e1e2e3] bg-white hover:shadow-card-cal transition-shadow p-5">
          <div class="flex items-baseline justify-between gap-4">
            <span class="text-base font-semibold text-[#242424] group-hover:text-brand-600 transition-colors">{s.data.title}</span>
            <span class="text-xs text-brand-600 opacity-0 group-hover:opacity-100 transition-opacity">Read &rarr;</span>
          </div>
          {s.data.description && (
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">{s.data.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
</ContentPage>
