---
import { getCollection } from 'astro:content';
import ContentPage from '../../layouts/ContentPage.astro';

const services = (await getCollection('services'))
  .filter((s) => !s.data.draft && s.id !== 'index')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<ContentPage
  title="Services"
  description="How I work with business owners, agencies, and investors: research graphs, knowledge portals, quant platforms, agent pipelines, and AI builds that hold up after the demo."
  breadcrumbLabel="devai.co.za"
  breadcrumbHref="/"
>
  <h1>Services</h1>
  <p>Five ways I help. They share one spine: the <a href="/method">method</a> behind them, systems built so you can see what is verified, what is guessed, and what is still open. Pick the one closest to your problem, or just <a href="mailto:info@devai.co.za">tell me what you are stuck on</a>.</p>

  <ol class="card-list">
    {services.map((s) => (
      <li>
        <h2 class="row-title">{s.data.title}</h2>
        {s.data.description && <p class="row-desc">{s.data.description}</p>}
        <a href={`/services/${s.id}`} class="read-button">
          Read more <span aria-hidden="true">&rarr;</span>
        </a>
      </li>
    ))}
  </ol>
</ContentPage>

<style>
  .card-list {
    list-style: none !important;
    padding-left: 0 !important;
    margin-top: 2.5rem;
  }
  .card-list > li {
    margin-top: 3rem;
    padding-left: 0;
  }
  .card-list > li:first-child { margin-top: 2rem; }
  .card-list > li::marker { content: none; }
  .card-list h2.row-title {
    margin-top: 0 !important;
    font-size: 1.5rem;
    line-height: 1.25;
    font-weight: 500;
    word-spacing: 0.1em;
    color: #242424;
  }
  @media (min-width: 768px) {
    .card-list h2.row-title { font-size: 1.875rem; }
  }
  .card-list p.row-desc {
    margin-top: 1rem !important;
    font-size: 1rem !important;
    color: #4b5563;
    line-height: 1.7;
    max-width: 65ch;
  }
  .read-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.375rem;
    background: #f3f4f6;
    color: #374151 !important;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: background-color 150ms ease, color 150ms ease;
  }
  .read-button:hover { background: #e5e7eb; color: #1f2937 !important; }
</style>
